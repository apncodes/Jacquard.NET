<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <!-- NativeAOT settings -->
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- StripSymbols requires llvm-objcopy on Linux; disable for local macOS builds -->
    <StripSymbols>false</StripSymbols>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- IL2026/IL3050 warnings come from generated tool wrapper code and AWS Lambda serializer internals.
         These are known-safe: the tool parameter types are simple strings, fully statically analyzable.
         IL2104 comes from AWSSDK.Core which is not fully trim-annotated yet.
         Suppress to keep the build output clean. -->
    <NoWarn>$(NoWarn);IL2026;IL3050;IL2104</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- AWS Lambda bootstrap -->
    <PackageReference Include="Amazon.Lambda.Core" Version="2.5.0" />
    <PackageReference Include="Amazon.Lambda.RuntimeSupport" Version="1.12.0" />
    <PackageReference Include="Amazon.Lambda.Serialization.SystemTextJson" Version="2.4.4" />
  </ItemGroup>

  <ItemGroup>
    <!-- Jacquard.NET NuGet packages -->
    <PackageReference Include="Jacquard.Core" Version="0.1.13" />
    <PackageReference Include="Jacquard.Models.Bedrock" Version="0.1.13" />
    <!-- Source generator is compile-time only — no runtime dependency -->
    <PackageReference Include="Jacquard.SourceGenerator" Version="0.1.13"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

</Project>
